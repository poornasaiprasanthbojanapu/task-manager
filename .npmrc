# Enforce the engines field — pnpm will ERROR (not just warn)
# if someone's Node or pnpm version doesn't meet requirements
engine-strict=true

# Hoist these packages to root node_modules so VS Code's
# language server and other tools can find them without
# needing to know about workspace package boundaries
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=*typescript*
public-hoist-pattern[]=*@types*

# Automatically install peer dependencies
# (React needs this so you don't manually add react-dom etc.)
auto-install-peers=true
